---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="Aaron Nathanael">
  <main id="home">
    <section class="hero">
      <a
        href={`${base}assets/img/profile/self-image.jpg`}
        class="lightbox-trigger fade-in"
      >
        <img
          src={`${base}assets/img/profile/self-image.jpg`}
          alt="Aaron Nathanael"
          class="profile-img"
        />
      </a>
      <h1 class="fade-in delay-1">Aaron Nathanael</h1>
      <p class="fade-in delay-2" style="margin-top: 16px;">
        Computer Science undergraduate at BINUS University. Actively learning
        Machine Learning, Data Science, and Web Development. Currently in an
        exchange program at Shibaura Institute of Technology, Tokyo.
      </p>
    </section>

    <section id="skills" class="section reveal">
      <h2 class="section-title">Technical Skills</h2>
      <div class="skills-container" id="skills-container">
        <span class="skill-pill">Python</span>
        <span class="skill-pill">C</span>
        <span class="skill-pill">PHP</span>
        <span class="skill-pill">JavaScript</span>
        <span class="skill-pill">HTML</span>
        <span class="skill-pill">CSS</span>
        <span class="skill-pill">MySQL</span>
        <span class="skill-pill">Laravel</span>
        <span class="skill-pill">Machine Learning</span>
        <span class="skill-pill">Computer Vision</span>
        <span class="skill-pill">Web Development</span>
      </div>
    </section>

    <section id="projects" class="section reveal">
      <h2 class="section-title">Selected Work</h2>
      <div class="project-grid">
        <div class="reveal">
          <a href={`${base}projects/posture-alert`} class="project-card">
            <div class="project-info">
              <h3>Posture Alert App</h3>
              <p>Posture Detection web using webcam.</p>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-1">
          <a href={`${base}projects/code-doc-gen`} class="project-card">
            <div class="project-info">
              <h3>Code Documentation Generator</h3>
              <p>Generates Python documentation.</p>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-2">
          <a href={`${base}projects/safefall`} class="project-card">
            <div class="project-info">
              <h3>SafeFall</h3>
              <p>Fall Detection web.</p>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-3">
          <a href={`${base}projects/route-planner`} class="project-card">
            <div class="project-info">
              <h3>Public Transport Route Planner</h3>
              <p>Public transport routing web.</p>
            </div>
          </a>
        </div>
        <div class="reveal">
          <a href={`${base}projects/crop-yield-predictor`} class="project-card">
            <div class="project-info">
              <h3>Crop Yield Predictor</h3>
              <p>Predicts agricultural yield.</p>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-1">
          <a
            href={`${base}projects/personality-predictor`}
            class="project-card"
          >
            <div class="project-info">
              <h3>Personality Predictor</h3>
              <p>
                Predicts personality traits based on users' clothing choice.
              </p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section id="experience" class="section reveal">
      <h2 class="section-title">Experience</h2>
      <div class="list-grid">
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title">Semi-Finalist (Top 1,898)</span>
            <span class="list-date">Feb 2024 - Oct 2024</span>
          </div>
          <div class="list-subtitle">
            Samsung Innovation Campus by Skilvul (Batch 5)
          </div>
          <div class="list-content">
            Intensive AI/ML, Python, and IoT bootcamps completed. Delivered a
            real-time fall detection application using YOLO computer vision
            models.
          </div>
          <a
            href={`${base}assets/img/certificates/sic5-semi-final.jpg`}
            class="proof-link">View Certificate &rarr;</a
          >
        </div>
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title">Participant</span>
            <span class="list-date">Jul 2023 - Aug 2023</span>
          </div>
          <div class="list-subtitle">
            Apple Developer Academy (iOS Foundation)
          </div>
          <div class="list-content">
            Engineered an AR-based iOS mobile application capable of projecting
            traditional Balinese house designs onto real-world surfaces.
          </div>
          <a
            href={`${base}assets/img/certificates/ios-foundation.jpg`}
            class="proof-link">View Certificate &rarr;</a
          >
        </div>
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title">Academic & Web Development Activist</span>
            <span class="list-date">Mar 2024 - Dec 2025</span>
          </div>
          <div class="list-subtitle">HIMTI BINUS University</div>
          <div class="list-content">
            Architected the frontend infrastructure for the official HIMTI
            website and systematically coordinated technical events for
            students.
          </div>
          <a
            href={`${base}assets/img/certificates/himti-web-development-activist.jpg`}
            class="proof-link">View Certificate &rarr;</a
          >
        </div>
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title">Learning & Training Activist</span>
            <span class="list-date">Jan 2024 - Jun 2024</span>
          </div>
          <div class="list-subtitle">Bina Nusantara Computer Club (BNCC)</div>
          <div class="list-content">
            Authored and structured comprehensive computer science learning
            modules utilized by fellow university students.
          </div>
        </div>
      </div>
    </section>

    <section id="education" class="section reveal">
      <h2 class="section-title">Education</h2>
      <div class="list-grid">
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title">Shibaura Institute of Technology</span>
            <span class="list-date">Current</span>
          </div>
          <div class="list-subtitle">Tokyo, Japan</div>
          <div class="list-content">
            International Student Exchange Program focused on expanding
            cross-cultural engineering perspectives.
          </div>
        </div>
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title">BINUS University</span>
            <span class="list-date">2023 - Present</span>
          </div>
          <div class="list-subtitle">Bachelor of Computer Science</div>
          <div class="list-content">
            Specializing in Artificial Intelligence and Web Development.
          </div>
        </div>
      </div>
    </section>

    <section id="achievements" class="section reveal">
      <h2 class="section-title">Achievements</h2>
      <div class="cert-grid">
        <div class="reveal">
          <a
            href={`${base}assets/img/certificates/deans-list.jpg`}
            class="cert-card"
          >
            <div
              class="cert-image"
              style={`background-image: url('${base}assets/img/certificates/deans-list.jpg'); background-color: #222;`}
            >
            </div>
            <div class="cert-info">
              <h3>Dean's List 2025</h3>
              <p>BINUS University School of Computer Science</p>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-1">
          <a
            href={`${base}assets/img/certificates/game-jam.jpg`}
            class="cert-card"
          >
            <div
              class="cert-image"
              style={`background-image: url('${base}assets/img/certificates/game-jam.jpg'); background-color: #1a1a1a;`}
            >
            </div>
            <div class="cert-info">
              <h3>2nd Runner-Up Game Jam</h3>
              <p>COMPFEST 17 by Indie Game Ignite</p>
            </div>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="main-footer">
    <div class="footer-content">
      <div class="social-links">
        <div class="social-item reveal" id="email-item">
          <a href="#" class="social-link" id="email-link" aria-label="Email">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <span class="link-text">aaronnathanaelishakleman@gmail.com</span>
          </a>
        </div>
        <div class="social-item reveal reveal-delay-1">
          <a
            href="https://github.com/CurvyCroissant"
            target="_blank"
            class="social-link"
            aria-label="GitHub"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
              ></path>
            </svg>
            <span class="link-text">github.com/CurvyCroissant</span>
          </a>
        </div>
        <div class="social-item reveal reveal-delay-2">
          <a
            href="https://www.linkedin.com/in/aaron-nathanael"
            target="_blank"
            class="social-link"
            aria-label="LinkedIn"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
            <span class="link-text">linkedin.com/in/aaron-nathanael</span>
          </a>
        </div>
      </div>
      <p class="footer-text reveal reveal-delay-3">
        &copy; 2026 Aaron Nathanael
      </p>
    </div>
  </footer>
</Layout>
