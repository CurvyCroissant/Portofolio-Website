---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="Aaron Nathanael">
  <main id="home">
    <section class="hero">
      <a
        href={`${base}/assets/img/profile/self-image.jpg`}
        class="lightbox-trigger fade-in"
      >
        <img
          src={`${base}/assets/img/profile/self-image.jpg`}
          alt="Aaron Nathanael"
          class="profile-img"
          loading="lazy"
          decoding="async"
        />
      </a>
      <h1 class="fade-in delay-1">Aaron Nathanael</h1>
      <p
        class="fade-in delay-2"
        style="margin-top: 16px;"
        data-i18n="hero-desc"
      >
        Computer Science undergraduate at BINUS University. Actively learning
        Machine Learning, Data Science, and Web Development. Currently in an
        exchange program at Shibaura Institute of Technology, Tokyo.
      </p>
    </section>

    <section id="experience" class="section reveal">
      <h2 class="section-title" data-i18n="sec-exp">Experience</h2>
      <div class="list-grid">
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title" data-i18n="exp-guide">Tour Guide</span>
            <span class="list-date" data-i18n="date-yummy"
              >Jun 2026 - Present</span
            >
          </div>
          <div class="list-subtitle">Yummy Guide</div>
          <div class="list-content" data-i18n="exp-guide-desc">
            Provide comprehensive guides entirely in English of the Ghibli
            Museum in Mitaka, Tokyo. The guests are mostly tourists travelling
            in Japan.
          </div>
        </div>
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title" data-i18n="exp-aca"
              >Academic Events Activist</span
            >
            <span class="list-date" data-i18n="date-himti-aca"
              >Mar 2025 - Dec 2025</span
            >
          </div>
          <div class="list-subtitle">
            Himpunan Mahasiswa Teknik Informatika (HIMTI), BINUS University
          </div>
          <div class="list-content" data-i18n="exp-aca-desc">
            Created and carried out events under HIMTI.
          </div>
        </div>
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title" data-i18n="exp-web"
              >Web Development Activist</span
            >
            <span class="list-date" data-i18n="date-himti-web"
              >Mar 2024 - Dec 2024</span
            >
          </div>
          <div class="list-subtitle">
            Himpunan Mahasiswa Teknik Informatika (HIMTI), BINUS University
          </div>
          <div class="list-content" data-i18n="exp-web-desc">
            Developed the frontend of HIMTI's website and other events using
            HTML, CSS, and JS.
          </div>
          <a
            href={`${base}/assets/img/certificates/himti-web-development-activist.jpg`}
            class="proof-link"
            data-i18n="view-cert">View Certificate</a
          >
        </div>
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title" data-i18n="exp-sic">Semi Finalist</span>
            <span class="list-date" data-i18n="date-sic"
              >Feb 2024 - Oct 2024</span
            >
          </div>
          <div class="list-subtitle">
            Samsung Innovation Campus by Skilvul (Batch 5)
          </div>
          <div class="list-content" data-i18n="exp-sic-desc">
            Completed the intensive bootcamps for AI/ML, Python, and IoT.
            Delivered "SafeFall", which is a real-time fall detection app using
            YOLO computer vision models. Successfully reached the semi finals as
            the top 80 out of 1,898 participants.
          </div>
          <a
            href={`${base}/assets/img/certificates/sic5-semi-final.jpg`}
            class="proof-link"
            data-i18n="view-cert">View Certificate</a
          >
        </div>
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title" data-i18n="exp-bncc"
              >Learning & Training Activist</span
            >
            <span class="list-date" data-i18n="date-bncc"
              >Jan 2024 - Jun 2024</span
            >
          </div>
          <div class="list-subtitle">
            Bina Nusantara Computer Club (BNCC), BINUS University
          </div>
          <div class="list-content" data-i18n="exp-bncc-desc">
            Planned out and created comprehensive computer science learning
            modules for university students.
          </div>
        </div>
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title" data-i18n="exp-ios">Participant</span>
            <span class="list-date" data-i18n="date-ios"
              >Jul 2023 - Aug 2023</span
            >
          </div>
          <div class="list-subtitle">
            iOS Foundation by Apple Developer Academy
          </div>
          <div class="list-content" data-i18n="exp-ios-desc">
            Developed an AR-based iOS mobile app which is able to project
            traditional Balinese house designs onto real-world surfaces.
          </div>
          <a
            href={`${base}/assets/img/certificates/ios-foundation.jpg`}
            class="proof-link"
            data-i18n="view-cert">View Certificate</a
          >
        </div>
      </div>
    </section>

    <section id="education" class="section reveal">
      <h2 class="section-title" data-i18n="sec-edu">Education</h2>
      <div class="list-grid">
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title">Shibaura Institute of Technology</span>
            <span class="list-date" data-i18n="date-sit"
              >Apr 2026 - Jul 2026</span
            >
          </div>
          <div class="list-subtitle" data-i18n="edu-sit-sub">
            Student Exchange Program
          </div>
          <div class="list-content" data-i18n="edu-sit-desc">
            Partook in a Student Exchange Program at Shibaura Institute of
            Technology, Tokyo. Learned plenty about engineering in Japan, as
            well as cross-cultural perspectives.
          </div>
        </div>
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title">BINUS University</span>
            <span class="list-date" data-i18n="date-binus"
              >Sep 2023 - Present</span
            >
          </div>
          <div class="list-subtitle" data-i18n="edu-binus-sub">
            Bachelor of Computer Science
          </div>
          <div class="list-content" data-i18n="edu-binus-desc">
            Computer Science Undergraduate with a cumulative GPA of 3.92. Within
            the Global Class Program, meaning that everything is presented in
            English, along with a semester of International Study Exchange.
            Currently pursuing Machine Learning, Data Science, and Web
            Development.
          </div>
        </div>
        <div class="list-item reveal">
          <div class="list-header">
            <span class="list-title">SMAK 1 BPK PENABUR Jakarta</span>
            <span class="list-date" data-i18n="date-smak"
              >Jul 2020 - Jun 2023</span
            >
          </div>
          <div class="list-subtitle" data-i18n="edu-smak-sub">
            High School Diplomat
          </div>
          <div class="list-content" data-i18n="edu-smak-desc">
            General high school in the Mathematics and Natural Sciences (MIPA)
            major.
          </div>
        </div>
      </div>
    </section>

    <section id="skills" class="section reveal">
      <h2 class="section-title" data-i18n="sec-skills">Technical Skills</h2>
      <div class="skills-container" id="skills-container">
        <span class="skill-pill">Python</span>
        <span class="skill-pill">C</span>
        <span class="skill-pill">PHP</span>
        <span class="skill-pill">JavaScript</span>
        <span class="skill-pill">HTML</span>
        <span class="skill-pill">CSS</span>
        <span class="skill-pill">MySQL</span>
        <span class="skill-pill">Laravel</span>
        <span class="skill-pill">Machine Learning</span>
        <span class="skill-pill">Computer Vision</span>
        <span class="skill-pill">Web Development</span>
      </div>
    </section>

    <section id="projects" class="section reveal">
      <h2 class="section-title" data-i18n="sec-proj">Projects</h2>
      <div class="project-grid">
        <div class="reveal">
          <a href={`${base}/projects/posture-alert`} class="project-card">
            <div class="project-info">
              <h3 data-i18n="proj-pa-title">Posture Alert App</h3>
              <p data-i18n="proj-pa-desc">
                Posture Detection web using webcam.
              </p>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-1">
          <a href={`${base}/projects/code-doc-gen`} class="project-card">
            <div class="project-info">
              <h3 data-i18n="proj-cd-title">Code Documentation Generator</h3>
              <p data-i18n="proj-cd-desc">Generates Python documentation.</p>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-2">
          <a href={`${base}/projects/safefall`} class="project-card">
            <div class="project-info">
              <h3 data-i18n="proj-sf-title">SafeFall</h3>
              <p data-i18n="proj-sf-desc">Fall Detection web.</p>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-3">
          <a href={`${base}/projects/route-planner`} class="project-card">
            <div class="project-info">
              <h3 data-i18n="proj-rp-title">Public Transport Route Planner</h3>
              <p data-i18n="proj-rp-desc">Public transport routing web.</p>
            </div>
          </a>
        </div>
        <div class="reveal">
          <a
            href={`${base}/projects/crop-yield-predictor`}
            class="project-card"
          >
            <div class="project-info">
              <h3 data-i18n="proj-cy-title">Crop Yield Predictor</h3>
              <p data-i18n="proj-cy-desc">Predicts agricultural yield.</p>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-1">
          <a
            href={`${base}/projects/personality-predictor`}
            class="project-card"
          >
            <div class="project-info">
              <h3 data-i18n="proj-pp-title">Personality Predictor</h3>
              <p data-i18n="proj-pp-desc">
                Predicts personality traits based on users' clothing choice.
              </p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section id="achievements" class="section reveal">
      <h2 class="section-title" data-i18n="sec-ach">Achievements</h2>
      <div class="cert-grid">
        <div class="reveal">
          <a
            href={`${base}/assets/img/certificates/deans-list.jpg`}
            class="cert-card"
          >
            <div
              class="cert-image"
              style={`background-image: url('${base}/assets/img/certificates/deans-list.jpg'); background-color: #222;`}
            >
            </div>
            <div class="cert-info">
              <h3 data-i18n="ach-dl">Dean's List 2025</h3>
              <p data-i18n="ach-dl-desc">
                BINUS University School of Computer Science
              </p>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-1">
          <a
            href={`${base}/assets/img/certificates/game-jam.jpg`}
            class="cert-card"
          >
            <div
              class="cert-image"
              style={`background-image: url('${base}/assets/img/certificates/game-jam.jpg'); background-color: #1a1a1a;`}
            >
            </div>
            <div class="cert-info">
              <h3 data-i18n="ach-gj">2nd Runner-Up Game Jam</h3>
              <p>COMPFEST 17 by Indie Game Ignite</p>
            </div>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="main-footer">
    <div class="footer-content">
      <div class="social-links">
        <div class="social-item reveal" id="email-item">
          <a href="#" class="social-link" id="email-link" aria-label="Email">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path><polyline points="22,6 12,13 2,6"></polyline></svg
            >
            <span class="link-text">aaronnathanaelishakleman@gmail.com</span>
          </a>
        </div>
        <div class="social-item reveal reveal-delay-1">
          <a
            href="https://github.com/CurvyCroissant"
            target="_blank"
            class="social-link"
            aria-label="GitHub"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
              ></path></svg
            >
            <span class="link-text">github.com/CurvyCroissant</span>
          </a>
        </div>
        <div class="social-item reveal reveal-delay-2">
          <a
            href="https://www.linkedin.com/in/aaron-nathanael"
            target="_blank"
            class="social-link"
            aria-label="LinkedIn"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path><rect x="2" y="9" width="4" height="12"></rect><circle
                cx="4"
                cy="4"
                r="2"></circle></svg
            >
            <span class="link-text">linkedin.com/in/aaron-nathanael</span>
          </a>
        </div>
      </div>
      <p class="footer-text reveal reveal-delay-3">
        &copy; 2026 Aaron Nathanael
      </p>
    </div>
  </footer>
</Layout>
