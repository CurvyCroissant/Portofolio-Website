---
import Layout from "../../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="Posture Alert App | Aaron Nathanael">
  <a href={`${base}/`} class="back-link" data-i18n="back-home">← Back to Home</a
  >
  <main class="section">
    <div class="project-detail">
      <div
        class="project-hero-image reveal"
        style="background: linear-gradient(135deg, #e0f2f1, #b2dfdb)"
      >
      </div>
      <h1
        class="section-title reveal reveal-delay-1"
        style="margin-bottom: 0; text-align: left; background: none; -webkit-text-fill-color: var(--text-color);"
        data-i18n="proj-pa-title"
      >
        Posture Alert App
      </h1>

      <div class="project-meta reveal reveal-delay-2">
        <div class="meta-item">
          <span class="meta-label" data-i18n="ctx-label">Context</span>
          <span class="meta-value" data-i18n="ctx-pe">Personal Project</span>
        </div>
        <div class="meta-item">
          <span class="meta-label" data-i18n="ts-label">Tech Stack</span>
          <span class="meta-value">Python, MediaPipe, OpenCV, Pandas</span>
        </div>
      </div>

      <div class="project-content-grid reveal reveal-delay-3">
        <div class="content-block">
          <h3 data-i18n="prob-label">The Problem</h3>
          <p data-i18n="pa-prob">
            Slouching causes back pain, but physical posture correctors are
            annoying to wear. Software alternatives exist, but they usually
            break if the user wears headphones or has a busy background.
          </p>
        </div>
        <div class="content-block">
          <h3 data-i18n="sol-label">The Solution</h3>
          <p data-i18n="pa-sol">
            A web app was built to track posture using a regular webcam. To fix
            the headphone issue, tracking was mapped to eye coordinates instead
            of ears. A calibration step was added to lock onto the user's size
            and ignore background movement.
          </p>
        </div>
      </div>

      <div class="content-block reveal" style="margin-bottom: 48px">
        <h3 data-i18n="imp-label">Impact</h3>
        <p data-i18n="pa-imp">
          A free, zero-hardware posture monitor that works in real-world
          conditions. It alerts the user when they slouch and provides
          exportable data on their session habits.
        </p>
        <a
          href="https://github.com/CurvyCroissant/Posture-Alert.git"
          target="_blank"
          class="repo-link"
          data-i18n="view-repo">View Repository →</a
        >
      </div>

      <h3 style="margin-top: 48px; margin-bottom: 24px" data-i18n="gal-label">
        Project Gallery
      </h3>
      <div class="cert-grid">
        <div class="reveal">
          <a
            href={`${base}/assets/img/projects/posture-alert/when-slouching.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/posture-alert/when-slouching.jpg`}
                alt="Slouch Detection"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: top;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="pa-gal-1">
                Slouch Detection
              </h3>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-1">
          <a
            href={`${base}/assets/img/projects/posture-alert/when-using-headphones.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/posture-alert/when-using-headphones.jpg`}
                alt="Occlusion Handling"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: top;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="pa-gal-2">
                Occlusion Handling
              </h3>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-2">
          <a
            href={`${base}/assets/img/projects/posture-alert/with-background-noise.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/posture-alert/with-background-noise.jpg`}
                alt="Background Filtering"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: top;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="pa-gal-3">
                Background Filtering
              </h3>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-3">
          <a
            href={`${base}/assets/img/projects/posture-alert/when-looking-down.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/posture-alert/when-looking-down.jpg`}
                alt="Head Tilt Detection"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: top;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="pa-gal-4">
                Head Tilt Detection
              </h3>
            </div>
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
