---
import Layout from "../../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="Code Documentation Generator | Aaron Nathanael">
  <a href={`${base}/`} class="back-link" data-i18n="back-home">← Back to Home</a
  >
  <main class="section">
    <div class="project-detail">
      <div
        class="project-hero-image reveal"
        style="background: linear-gradient(135deg, #1e3a8a, #172554)"
      >
      </div>
      <h1
        class="section-title reveal reveal-delay-1"
        style="margin-bottom: 0; text-align: left; background: none; -webkit-text-fill-color: var(--text-color);"
        data-i18n="proj-cd-title"
      >
        Code Documentation Generator
      </h1>

      <div class="project-meta reveal reveal-delay-2">
        <div class="meta-item">
          <span class="meta-label" data-i18n="ctx-label">Context</span>
          <span class="meta-value" data-i18n="ctx-pe">Personal Project</span>
        </div>
        <div class="meta-item">
          <span class="meta-label" data-i18n="ts-label">Tech Stack</span>
          <span class="meta-value">Python, Qwen2.5, HuggingFace, AST</span>
        </div>
      </div>

      <div class="project-content-grid reveal reveal-delay-3">
        <div class="content-block">
          <h3 data-i18n="prob-label">The Problem</h3>
          <p data-i18n="cd-prob">
            Writing documentation is tedious. Existing AI tools often
            hallucinate, making up variables that don't exist in the code, or
            they cost money to use via cloud APIs.
          </p>
        </div>
        <div class="content-block">
          <h3 data-i18n="sol-label">The Solution</h3>
          <p data-i18n="cd-sol">
            A local-first Python tool was created using the Qwen2.5 model. By
            strictly enforcing JSON outputs, it avoids chatty responses. A
            validation step was added to check the AI's output against the
            actual code's Abstract Syntax Tree (AST) to completely block fake
            parameters.
          </p>
        </div>
      </div>

      <div class="content-block reveal" style="margin-bottom: 48px">
        <h3 data-i18n="imp-label">Impact</h3>
        <p data-i18n="cd-imp">
          Fast, free, and accurate docstrings generated in 5-20 seconds per file
          without needing an internet connection. The output quality was
          verified using standard NLP benchmarks like BLEU and ROUGE-L.
        </p>
        <a
          href="https://github.com/CurvyCroissant/Code-Documentation-Generator.git"
          target="_blank"
          class="repo-link"
          data-i18n="view-repo">View Repository →</a
        >
      </div>

      <h3 style="margin-top: 48px; margin-bottom: 24px" data-i18n="gal-label">
        Project Gallery
      </h3>
      <div class="cert-grid">
        <div class="reveal">
          <a
            href={`${base}/assets/img/projects/code-documentation-generator/website.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/code-documentation-generator/website.jpg`}
                alt="Web Interface"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: center;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="cd-gal-1">
                Web Interface
              </h3>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-1">
          <a
            href={`${base}/assets/img/projects/code-documentation-generator/outputted-documentation.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/code-documentation-generator/outputted-documentation.jpg`}
                alt="Validated Outputs"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: left;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="cd-gal-2">
                Validated Outputs
              </h3>
            </div>
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
