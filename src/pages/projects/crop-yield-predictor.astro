---
import Layout from "../../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="Crop Yield Predictor | Aaron Nathanael">
  <a href={`${base}/`} class="back-link">← Back to Home</a>
  <main class="section">
    <div class="project-detail">
      <div
        class="project-hero-image reveal"
        style="background: linear-gradient(135deg, #064e3b, #022c22)"
      >
      </div>
      <h1
        class="section-title reveal reveal-delay-1"
        style="margin-bottom: 0; text-align: left; background: none; -webkit-text-fill-color: var(--text-color);"
      >
        Crop Yield Predictor
      </h1>

      <div class="project-meta reveal reveal-delay-2">
        <div class="meta-item">
          <span class="meta-label">Context</span>
          <span class="meta-value">Personal Project</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Tech Stack</span>
          <span class="meta-value"
            >Python, Scikit-Learn, Pandas, Matplotlib</span
          >
        </div>
      </div>

      <div class="project-content-grid reveal reveal-delay-3">
        <div class="content-block">
          <h3>The Problem</h3>
          <p>
            Predicting how much a farm will produce is tough because weather and
            resources vary wildly. Inaccurate predictions lead to wasted
            resources and poor financial planning for farmers.
          </p>
        </div>
        <div class="content-block">
          <h3>The Solution</h3>
          <p>
            Raw agricultural data was cleaned and processed to handle missing
            values, and high-cardinality locations were categorized using
            One-Hot Encoding. Several machine learning models were then
            benchmarked against each other to determine which predicted yields
            best based on inputs like rainfall, temperature, and pesticides.
          </p>
        </div>
      </div>

      <div class="content-block reveal" style="margin-bottom: 48px">
        <h3>Impact</h3>
        <p>
          The final Gradient Boosting model reached 96% accuracy. A simulation
          was also run to identify anomaly clusters and show how this data could
          be used to target underperforming farms, complete with an estimated
          financial ROI.
        </p>
      </div>

      <h3 style="margin-top: 48px; margin-bottom: 24px">Project Gallery</h3>
      <div class="cert-grid">
        <div class="reveal">
          <a
            href={`${base}/assets/img/projects/crop-yield-predictor/model-benchmarking.jpg`}
            class="cert-card"
          >
            <div
              class="cert-image"
              style={`background-image: url('${base}/assets/img/projects/crop-yield-predictor/model-benchmarking.jpg');`}
            >
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0">Model Benchmarking</h3>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-1">
          <a
            href={`${base}/assets/img/projects/crop-yield-predictor/anomaly-detection.jpg`}
            class="cert-card"
          >
            <div
              class="cert-image"
              style={`background-image: url('${base}/assets/img/projects/crop-yield-predictor/anomaly-detection.jpg');`}
            >
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0">Anomaly Detection</h3>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-2">
          <a
            href={`${base}/assets/img/projects/crop-yield-predictor/business-simulation.jpg`}
            class="cert-card"
          >
            <div
              class="cert-image"
              style={`background-image: url('${base}/assets/img/projects/crop-yield-predictor/business-simulation.jpg');`}
            >
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0">Business Value Simulation</h3>
            </div>
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
