---
import Layout from "../../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="SafeFall: Fall Detection App | Aaron Nathanael">
  <a href={`${base}/`} class="back-link" data-i18n="back-home">← Back to Home</a
  >
  <main class="section">
    <div class="project-detail">
      <div
        class="project-hero-image reveal"
        style="background: linear-gradient(135deg, #7f1d1d, #450a0a)"
      >
      </div>
      <h1
        class="section-title reveal reveal-delay-1"
        style="margin-bottom: 0; text-align: left; background: none; -webkit-text-fill-color: var(--text-color);"
        data-i18n="proj-sf-title"
      >
        SafeFall: Fall Detection App
      </h1>

      <div class="project-meta reveal reveal-delay-2">
        <div class="meta-item">
          <span class="meta-label" data-i18n="ctx-label">Context</span>
          <span class="meta-value">Samsung Innovation Campus</span>
        </div>
        <div class="meta-item">
          <span class="meta-label" data-i18n="ts-label">Tech Stack</span>
          <span class="meta-value">Python, YOLOv8, OpenCV, Streamlit</span>
        </div>
      </div>

      <div class="project-content-grid reveal reveal-delay-3">
        <div class="content-block">
          <h3 data-i18n="prob-label">The Problem</h3>
          <p data-i18n="sf-prob">
            Elderly fall detection usually relies on smartwatches or pendants.
            Unfortunately, these devices are easily forgotten, taken off to
            charge, or actively avoided by the users who need them most.
          </p>
        </div>
        <div class="content-block">
          <h3 data-i18n="sol-label">The Solution</h3>
          <p data-i18n="sf-sol">
            A YOLOv8 computer vision model was trained to detect falls using
            standard camera feeds. It tracks sudden vertical movement and logs
            each event with a confidence score, sending alerts without any
            physical interaction from the user.
          </p>
        </div>
      </div>

      <div class="content-block reveal" style="margin-bottom: 48px">
        <h3 data-i18n="imp-label">Impact</h3>
        <p data-i18n="sf-imp">
          A non-intrusive safety net deployed to work continuously in the
          background. The solution was selected as a Top Semi-Finalist
          submission out of 1,898 participating teams in the Samsung Innovation
          Campus program.
        </p>
        <a
          href="https://github.com/CurvyCroissant/SafeFall.git"
          target="_blank"
          class="repo-link"
          data-i18n="view-repo">View Repository →</a
        >
      </div>

      <h3 style="margin-top: 48px; margin-bottom: 24px" data-i18n="gal-label">
        Project Gallery
      </h3>
      <div class="cert-grid">
        <div class="reveal">
          <a
            href={`${base}/assets/img/projects/safefall/website.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/safefall/website.jpg`}
                alt="Web Interface"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: center;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="cd-gal-1">
                Web Interface
              </h3>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-1">
          <a
            href={`${base}/assets/img/projects/safefall/fall-detected.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/safefall/fall-detected.jpg`}
                alt="Fall Detected"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: top;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="sf-gal-1">
                Fall Detected
              </h3>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-2">
          <a
            href={`${base}/assets/img/projects/safefall/no-fall-detected.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/safefall/no-fall-detected.jpg`}
                alt="Normal State"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: top;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="sf-gal-2">
                Normal State
              </h3>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-3">
          <a
            href={`${base}/assets/img/projects/safefall/fall-detection-summary.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/safefall/fall-detection-summary.jpg`}
                alt="Event Logs"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: left;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="sf-gal-3">Event Logs</h3>
            </div>
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
