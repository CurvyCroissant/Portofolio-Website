---
import Layout from "../../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="Personality Predictor App | Aaron Nathanael">
  <a href={`${base}/`} class="back-link" data-i18n="back-home">← Back to Home</a
  >
  <main class="section">
    <div class="project-detail">
      <div
        class="project-hero-image reveal"
        style="background: linear-gradient(135deg, #831843, #4c0519)"
      >
      </div>
      <h1
        class="section-title reveal reveal-delay-1"
        style="margin-bottom: 0; text-align: left; background: none; -webkit-text-fill-color: var(--text-color);"
        data-i18n="proj-pp-title"
      >
        Personality Predictor App
      </h1>

      <div class="project-meta reveal reveal-delay-2">
        <div class="meta-item">
          <span class="meta-label" data-i18n="ctx-label">Context</span>
          <span class="meta-value" data-i18n="ctx-ac">Academic Project</span>
        </div>
        <div class="meta-item">
          <span class="meta-label" data-i18n="ts-label">Tech Stack</span>
          <span class="meta-value">Python, PyTorch, Flask</span>
        </div>
      </div>

      <div class="project-content-grid reveal reveal-delay-3">
        <div class="content-block">
          <h3 data-i18n="prob-label">The Problem</h3>
          <p data-i18n="pp-prob">
            Personality tests traditionally rely on self-reported surveys, which
            are inherently biased by how individuals wish to be perceived. They
            lack an objective, visual correlation to an individual's actual
            presentation to the outside world.
          </p>
        </div>
        <div class="content-block">
          <h3 data-i18n="sol-label">The Solution</h3>
          <p data-i18n="pp-sol">
            A PyTorch neural network was developed to analyze photographs of
            user outfits. The system programmatically extracts specific fashion
            features and processes them through a classification model, mapping
            visual clothing choices directly to the Big Five (OCEAN) personality
            traits.
          </p>
        </div>
      </div>

      <div class="content-block reveal" style="margin-bottom: 48px">
        <h3 data-i18n="imp-label">Impact</h3>
        <p data-i18n="pp-imp">
          An interactive web application was deployed, seamlessly combining
          behavioral psychology with computer vision. It provides users with
          instant, AI-driven psychological predictions to contrast against their
          own self-assessments.
        </p>
      </div>

      <h3 style="margin-top: 48px; margin-bottom: 24px" data-i18n="gal-label">
        Project Gallery
      </h3>
      <div class="cert-grid">
        <div class="reveal">
          <a
            href={`${base}/assets/img/projects/personality-predictor/1.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/personality-predictor/1.jpg`}
                alt="Upload & Survey"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: top;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="pp-gal-1">
                Upload & Survey
              </h3>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-1">
          <a
            href={`${base}/assets/img/projects/personality-predictor/2.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/personality-predictor/2.jpg`}
                alt="AI Trait Analysis"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: top;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="pp-gal-2">
                AI Trait Analysis
              </h3>
            </div>
          </a>
        </div>
        <div class="reveal reveal-delay-2">
          <a
            href={`${base}/assets/img/projects/personality-predictor/3.jpg`}
            class="cert-card"
          >
            <div class="cert-image">
              <img
                src={`${base}/assets/img/projects/personality-predictor/3.jpg`}
                alt="Trait Breakdowns"
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; object-position: top;"
              />
            </div>
            <div class="cert-info">
              <h3 style="margin-bottom: 0" data-i18n="pp-gal-3">
                Trait Breakdowns
              </h3>
            </div>
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
